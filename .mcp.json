{
  "name": "weather-ai-mcp",
  "description": "> **By [MEOK AI Labs](https://meok.ai)** \u2014 Sovereign AI tools for everyone.",
  "version": "1.0.0",
  "tools": [
    {
      "name": "get_current_conditions",
      "description": "Get current weather conditions for a city.",
      "parameters": {
        "type": "object",
        "properties": {
          "city": {
            "type": "string"
          },
          "units": {
            "type": "string"
          }
        },
        "required": [
          "city"
        ]
      }
    },
    {
      "name": "get_forecast",
      "description": "Get multi-day weather forecast for a city.",
      "parameters": {
        "type": "object",
        "properties": {
          "city": {
            "type": "string"
          },
          "days": {
            "type": "integer"
          },
          "units": {
            "type": "string"
          }
        },
        "required": [
          "city"
        ]
      }
    },
    {
      "name": "get_historical_weather",
      "description": "Get historical weather data for a city and date range.",
      "parameters": {
        "type": "object",
        "properties": {
          "city": {
            "type": "string"
          },
          "start_date": {
            "type": "string"
          },
          "end_date": {
            "type": "string"
          },
          "units": {
            "type": "string"
          }
        },
        "required": [
          "city",
          "start_date",
          "end_date"
        ]
      }
    },
    {
      "name": "get_agricultural_alerts",
      "description": "Get agricultural weather alerts and growing condition analysis.",
      "parameters": {
        "type": "object",
        "properties": {
          "city": {
            "type": "string"
          },
          "crop_type": {
            "type": "string"
          }
        },
        "required": [
          "city"
        ]
      }
    },
    {
      "name": "get_severe_weather_warnings",
      "description": "Check for severe weather warnings and safety advisories.",
      "parameters": {
        "type": "object",
        "properties": {
          "city": {
            "type": "string"
          }
        },
        "required": [
          "city"
        ]
      }
    }
  ]
}